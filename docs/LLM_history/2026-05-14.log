2. Создайте функцию-утилиту для форматирования
В index.ts или utils.ts добавьте функцию, которая будет автоматически выбирать нужное количество знаков.
typescript
import { formatUnits } from 'ethers';
import { CONFIG } from './config.js';

/**
 * Форматирует значение токена на основе символа
 * @param amount - значение в wei (BigInt или string)
 * @param symbol - символ токена (например, 'USDC', 'ETH')
 */
export function formatTokenAmount(amount: bigint | string, symbol: string): string {
    // Берем decimals для конкретного токена или используем default (18)
    const decimals = CONFIG.TOKEN_DECIMALS[symbol] || CONFIG.TOKEN_DECIMALS.default;
    return formatUnits(amount, decimals);
}
