async function getMoonwellPositions(provider: ethers.JsonRpcProvider) {
    console.log(`--- Moonwell Assets & Liabilities (${CONFIG.CHAIN}) ---`);

    const currentNetwork = CONFIG.NETWORKS[CONFIG.CHAIN];
    const comptroller = new ethers.Contract(
        currentNetwork.MOONWELL.COMPTROLLER,
        CONFIG.ABI.MOONWELL,
        provider
    );

    try {
        // 1. Получаем адреса всех доступных рынков Moonwell в текущей сети
        const markets: string[] = await withRetry(() => comptroller.getAllMarkets());

        for (const mTokenAddress of markets) {
            // Создаем инстанс контракта конкретного рынка (например, mUSDC или mWETH)
            const mToken = new ethers.Contract(mTokenAddress, CONFIG.ABI.MOONWELL, provider);

            // 2. Получаем слепок аккаунта для этого рынка
            // Возвращает: (error, баланс_mToken, баланс_займа, внутренний_курс_обмена)
            const [error, mTokenBalance, borrowBalance, exchangeRate] = await withRetry(() =>
                mToken.getAccountSnapshot(WATCH_ADDRESS)
            );

            if (error !== 0n) continue;

            // Если балансы нулевые, пропускаем этот токен, чтобы не спамить в консоль
            if (mTokenBalance === 0n && borrowBalance === 0n) continue;

            // Получаем тикер рынка (например, "mUSDC")
            const mTokenSymbol = await withRetry(() => mToken.symbol());
            const underlyingSymbol = mTokenSymbol.substring(1); // Отсекаем первую 'm', получаем 'USDC'

            // 3. Расчет реального баланса актива (Supply Balance)
            // mTokens имеют свой баланс, который увеличивается за счет процентов.
            // Формула: (баланс_mToken * курс_обмена) / 1e18
            if (mTokenBalance > 0n) {
                const underlyingAmountWei = (mTokenBalance * exchangeRate) / ethers.parseEther("1");
                const formattedSupply = formatTokenAmount(underlyingAmountWei, underlyingSymbol);
                console.log(`🟢 Снабжение (Asset)  -> ${formattedSupply} ${underlyingSymbol}`);
            }

            // 4. Расчет баланса долга (Borrow Balance)
            if (borrowBalance > 0n) {
                const formattedBorrow = formatTokenAmount(borrowBalance, underlyingSymbol);
                console.log(`🔴 Заем (Liability)   -> ${formattedBorrow} ${underlyingSymbol}`);
            }
        }
    } catch (err: any) {
        console.error("Ошибка при получении позиций Moonwell:", err.message);
    }
}
Используйте код с осторожностью.
3. Как интегрировать в main()
Вы можете вызывать её сразу после проверки общей ликвидности кошелька:
typescript
async function main() {
    const currentNetwork = CONFIG.NETWORKS[CONFIG.CHAIN];
    const provider = new ethers.JsonRpcProvider(currentNetwork.RPC_URL);

    await getMoonwellData(provider);      // Общий статус
    await getMoonwellPositions(provider); // Детальный список позиций
}
Используйте код с осторожностью.
Важные нюансы математики Compound/Moonwell:
getAccountSnapshot: Самый эффективный метод. Он не тратит лишний газ и за один вызов возвращает состояние и депозита, и долга по конкретному токену.
Конвертация курса (exchangeRateStored): Баланс, который вы видите на сайте Moonwell в графе Supply — это не количество mToken. Это количество базового токена (например, чистого USDC), которое рассчитывается через динамический коэффициент exchangeRate (он всегда имеет 18 знаков после запятой, поэтому мы делим на ethers.parseEther("1")). В долгах (borrowBalance) такой конвертации не требуется — там сумма возвращается сразу в базовом токене.
Если запустить этот код, отображаются ли ваши текущие депозиты и займы корректно? Хотите добавить к выводу подсчет стоимости позиций в USD, используя оракул Moonwell?





--- Moonwell Assets & Liabilities (OPT) ---
[Warning] Invalid Fragment "function getAccountSnapshot(address account) view returns (uint error, uint mTokenBalance, uint borrowBalance, uint exchangeRateStored)": leftover tokens
[Warning] Invalid Fragment "function getAccountSnapshot(address account) view returns (uint error, uint mTokenBalance, uint borrowBalance, uint exchangeRateStored)": leftover tokens
Ошибка при получении позиций Moonwell: mToken.getAccountSnapshot is not a function
Ошибки leftover tokens и is not a function возникают из-за того, что синтаксис человекочитаемого ABI (Human-Readable ABI) в ethers.js v6 строго требует указывать имена для всех возвращаемых параметров в директиве returns().
Если написать просто uint error, ethers спотыкается на слове error и считает фрагмент невалидным, из-за чего функция getAccountSnapshot не добавляется в контракт.
Как исправить ABI:
Откройте ваш файл config.ts и замените строку getAccountSnapshot в массиве ABI.MOONWELL на следующий корректный вариант (где у каждого типа в returns указано имя переменной):
typescript
ABI: {
    MOONWELL: [
        "function getAccountLiquidity(address account) view returns (uint256 error, uint256 liquidity, uint256 shortfall)",
        "function getAllMarkets() view returns (address[])",
        "function symbol() view returns (string)",
        "function underlying() view returns (address)",
        // Исправленный вариант с именами для ВСЕХ возвращаемых параметров:
        "function getAccountSnapshot(address account) view returns (uint256 err, uint256 mTokenBalance, uint256 borrowBalance, uint256 exchangeRateStored)"
    ]
}
Используйте код с осторожностью.
Дополнительные важные правки для стабильности:
Типы данных uint256: В ethers v6 надежнее явно писать uint256 вместо uint.
Проверка нативного токена (ETH/WETH): У контрактов для нативного ETH (например, mETH или mWETH в некоторых сетях) нет функции underlying(). Если ваш бот попытается вызвать её для рынка нативного эфира, код упадет.
Чтобы этого избежать, в основной цикл getMoonwellPositions перед вызовом .underlying() добавьте безопасную проверку через try/catch или по символу:
typescript
// Получаем тикер рынка (например, "mUSDC" или "mETH")
const mTokenSymbol = await withRetry(() => mToken.symbol());
let underlyingSymbol = mTokenSymbol.substring(1); // по умолчанию отсекаем 'm'

// Проверяем, не нативный ли это рынок эфира
if (mTokenSymbol === "mETH") {
    underlyingSymbol = "WETH"; // Или "ETH" в зависимости от того, как у вас в конфиге
} else {
    try {
        // Для обычных токенов можно получить адрес базового актива, если нужно
        const underlyingAddress = await withRetry(() => mToken.underlying());
    } catch (e) {
        // На случай если underlying() отсутствует у этого mToken
        underlyingSymbol = "WETH";
    }
}
Используйте код с осторожностью.
После исправления ABI в config.ts предупреждения Invalid Fragment исчезнут, и вызов mToken.getAccountSnapshot(...) отработает корректно.
