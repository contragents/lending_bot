    CHAIN: 'BASE' | 'OPT'; // Ограничиваем выбор сетей
    ZEROX_API_KEY: string;
    SLIPPAGE: number;
    NETWORKS: {
        [key in 'BASE' | 'OPT']: NetworkSettings;
    };
    ABI: {
        MOONWELL: string[];
    };
}

export const CONFIG: AppConfig = {
    CHAIN: (process.env.CHAIN as 'BASE' | 'OPT') || 'BASE',
    ZEROX_API_KEY: process.env.ZEROX_API_KEY || '',
    SLIPPAGE: 0.005,

    NETWORKS: {
        BASE: {
            RPC_URL: process.env.BASE_RPC_URL || '',
            TOKENS: {
                WETH: getAddress("0x4200000000000000000000000000000000000006"),
                USDC: getAddress("0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"),
                DAI:  getAddress("0x50c5725949A6F0c72E6C45641f24029a217df880"),
            },
            MOONWELL: {
                COMPTROLLER: getAddress("0xfBb211A5396424b2D3929156708854D7474f0221"),
            }
        },
        OPT: {
            RPC_URL: process.env.OPTIMISM_RPC_URL || '',
            TOKENS: {
                WETH: getAddress("0x4200000000000000000000000000000000000006"),
                USDC: getAddress("0x0b2c639c533813f4aa9d7837caf62653d097ff85"),
                DAI:  getAddress("0xda10009cbd5d07dd0cecc66161fc93d7c9000da1"),
            },
            MOONWELL: {
                COMPTROLLER: getAddress("0xCa889f40aae37FFf165BccF69aeF1E82b5C511B9"),
            }
        }
    },

    ABI: {
        MOONWELL: [
            "function getAccountLiquidity(address account) view returns (uint, uint, uint)",
            "function getAllMarkets() view returns (address[])"
        ]
